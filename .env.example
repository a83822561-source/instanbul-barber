# ─────────────────────────────────────────────────────────────────────
# Google Places API — live ratings & reviews
# ─────────────────────────────────────────────────────────────────────
# Copy this file to `.env.local` and fill in both values.
# Without these, the site falls back to the curated reviews in lib/site.ts.
#
# 1. Create a Google Cloud project + enable the "Places API"
#    https://console.cloud.google.com/apis/library/places-backend.googleapis.com
# 2. Generate an API key and restrict it to "Places API" + your domain.
# 3. Find the shop's Place ID:
#    https://developers.google.com/maps/documentation/places/web-service/place-id
#
# Note: Google's Places API returns at most 5 reviews per request, sorted
# by relevance. Cached server-side for 6h (see lib/google-reviews.ts).

GOOGLE_PLACES_API_KEY=
GOOGLE_PLACE_ID=
